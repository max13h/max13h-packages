---
import { Icon } from "astro-icon/components"
import UIDarkModeBtn from "UILangSwitchBtn.astro"
import UILangSwitchBtn from "./UILangSwitchBtn.astro"
import { getLocaleFromUrl } from "@max13h/i18n"
import faviconUrl from "../assets/favicon.svg"
import type { IconElement, RelatedLink } from "../types"

interface Props {
  relatedLinks?: RelatedLink[]
  homeLink?: boolean
  switchPath?: string
  siteLabel?: string
  siteHref?: string
}

const {
  relatedLinks,
  homeLink = true,
  switchPath,
  siteLabel,
  siteHref,
} = Astro.props

const locale = getLocaleFromUrl(Astro.url)
const labelsByLocale = {
  en: {
    homeAlt: "Link to home page",
    github: "Link to my GitHub profile",
    linkedin: "Link to my LinkedIn profile",
  },
  fr: {
    homeAlt: "Lien vers la page d'accueil",
    github: "Lien vers mon profil GitHub",
    linkedin: "Lien vers mon profil LinkedIn",
  },
} as const
const labels = labelsByLocale[locale] ?? labelsByLocale.fr

const icons: IconElement[] = [
  {
    link: "https://github.com/max13h/",
    name: "github",
    title: labels.github,
  },
  {
    link: "https://www.linkedin.com/in/hmae/",
    name: "linkedin",
    title: labels.linkedin,
  },
]

const homeLabel = siteLabel ?? "blog.hmae.fr"
const homeHref = siteHref ?? `/${locale}/`
---

<nav>
  {
    homeLink && (
      <a href={homeHref} class="home">
        <img src={faviconUrl.src} alt={labels.homeAlt} />
        <span>{homeLabel}</span>
      </a>
    )
  }

  <div class="links">
    {
      relatedLinks && relatedLinks.length && (
        <div class="related">
          {relatedLinks.map((link) => (
            <>
              <a href={link.link} target="_blank">
                <p>{link.title}</p>
                <Icon name="external-link" size="1rem" />
              </a>
              <span aria-hidden="true">|</span>
            </>
          ))}
        </div>
      )
    }
    <div class="social-media">
      {
        icons.map((icon) => (
          <a href={icon.link} target="_blank">
            <Icon name={icon.name} title={icon.title} />
          </a>
        ))
      }
    </div>
    <span aria-hidden="true">|</span>
    <div class="settings">
      <UILangSwitchBtn switchPath={switchPath} />
      <UIDarkModeBtn />
    </div>
  </div>
</nav>

<style>
  nav {
    display: flex;
    justify-content: space-between;
    padding: 1rem;
    position: sticky;
    width: 100%;
    top: 0;

    & .home {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      position: relative;
      color: inherit;
      text-decoration: none;
      font-size: 1.125rem;

      & img {
        width: 1.5rem;
      }
    }

    & .links {
      display: flex;
      align-items: center;
      gap: 1rem;

      & .related {
        display: flex;
        align-items: center;
        gap: 1rem;

        & a {
          display: inline-flex;
          align-items: center;
          gap: 0.25rem;

          & p {
            font-size: 1.125rem;
          }

          & svg {
            font-size: 1.5rem;
          }
        }
      }

      & .social-media,
      .settings {
        display: flex;
        align-items: center;
        gap: 0.5rem;
      }

      & a {
        color: inherit;

        &:visited {
          color: inherit;
        }
      }

      & svg {
        font-size: 1.5rem;
      }
    }
  }

  @media (max-width: 1280px) {
    nav {
      backdrop-filter: blur(1rem);
      & .home span {
        display: none;
      }
    }
  }
</style>
